[Unit]
Description=Sistema Shambala - Centro Espirita Shambala
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=USUARIO
WorkingDirectory=/opt/shambala
ExecStart=/opt/shambala/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
# Ambiente
Environment="PATH=/opt/shambala/.venv/bin:/usr/local/bin:/usr/bin"

[Install]
WantedBy=multi-user.target
